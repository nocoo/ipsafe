{
  "name": "ipsafe",
  "version": "1.0.3",
  "description": "A CLI tool that validates network connectivity before executing commands",
  "main": "index.js",
  "bin": {
    "ipsafe": "bin/ipsafe.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --max-warnings=0 bin/ lib/ __tests__/",
    "lint:fix": "eslint --max-warnings=0 bin/ lib/ __tests__/ --fix",
    "verify": "npm run lint && npm test",
    "prepublishOnly": "npm run verify",
    "prepare": "husky"
  },
  "keywords": [
    "cli",
    "network",
    "connectivity",
    "safe",
    "command"
  ],
  "author": "nocoo",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.29.0",
    "husky": "^9.1.7",
    "vitest": "^4.1.5"
  }
}
